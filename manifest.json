{
  "manifest_version": 3,
  "name": "LLM Scroll Navigator",
  "version": "1.0",
  "description": "Keyboard and UI navigation for Prompts and Code Blocks on ChatGPT, Claude, and Gemini.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://aistudio.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}